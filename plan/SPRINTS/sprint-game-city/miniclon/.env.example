NODERED_CREDENTIAL_SECRET=change-me-local-secret
# Pin VPS (OCI NODE_RED_VERSION=v5.0.1; no :latest en el clon)
NODERED_BASE_IMAGE=nodered/node-red:5.0.1
NODERED_LOG_LEVEL=info
ROOMS_BIND_HOST=0.0.0.0
ROOMS_SECRETS_FILE=/run/secrets/rooms/rooms-secrets.json
ROOMS_DEFAULT_ROOM=ROOMS_LAB
# Cliente federado (host / segundo proceso Node-RED)
ROOMS_USER=miniclon-client
ROOMS_ROOM=ROOMS_LAB
ROOMS_SECRET=lab-dev-token
