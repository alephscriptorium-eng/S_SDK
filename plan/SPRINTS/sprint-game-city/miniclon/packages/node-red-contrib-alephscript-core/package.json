{
  "name": "node-red-contrib-alephscript-core",
  "version": "0.3.0",
  "description": "Core Node-RED nodes for AlephScript Socket.IO protocol integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc --build",
    "build:full": "npm run clean && npm run build && npm run copy:html",
    "copy:html": "node scripts/postbuild.cjs",
    "clean": "node -e \"const fs=require('fs'); if(fs.existsSync('dist')) fs.rmSync('dist', {recursive:true}); if(fs.existsSync('tsconfig.tsbuildinfo')) fs.rmSync('tsconfig.tsbuildinfo'); console.log('Cleaned dist/')\"",
    "test": "echo 'No tests yet for AlephScript Core'",
    "prepublishOnly": "npm run build:full"
  },
  "keywords": [
    "node-red",
    "alephscript",
    "socket.io",
    "mcp",
    "rooms",
    "core"
  ],
  "node-red": {
    "nodes": {
      "alephscript-core-config": "dist/nodes/alephscript-core-config.js",
      "alephscript-core-client": "dist/nodes/alephscript-core-client.js",
      "alephscript-core-format": "dist/nodes/alephscript-core-format.js"
    }
  },
  "dependencies": {
    "@alephscript/mcp-core-sdk": "^1.5.0",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-red": "^1.3.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "node-red": ">=3.0.0"
  },
  "author": {
    "name": "AlephScript Ops",
    "email": "ops@escrivivir.co",
    "url": "https://escrivivir.co"
  },
  "maintainers": [
    {
      "name": "AlephScript Ops",
      "email": "ops@escrivivir.co",
      "url": "https://escrivivir.co"
    }
  ],
  "license": "MIT"
}
