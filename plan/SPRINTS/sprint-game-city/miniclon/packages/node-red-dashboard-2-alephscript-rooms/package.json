{
  "name": "node-red-dashboard-2-alephscript-rooms",
  "version": "0.3.0",
  "description": "Node-RED Dashboard 2 Rooms MVP for AlephScript using @alephscript/mcp-core-sdk",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "resources/**/*",
    "ui/**/*",
    "vite.config.mjs",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc --build",
    "build:full": "npm run clean && npm run build && npm run copy:html && npm run build:ui",
    "build:ui": "vite build",
    "copy:html": "node scripts/postbuild.cjs",
    "dev": "npm run dev:ts & npm run watch:html",
    "dev:ts": "tsc --watch",
    "dev:ui": "vite build --watch",
    "watch:html": "echo 'HTML watch not implemented - copy manually after changes'",
    "lint": "eslint src --ext .ts",
    "test": "echo 'No tests yet for AlephScript Rooms'",
    "clean": "node -e \"const fs=require('fs'); ['dist','resources'].forEach((dir)=>{ if(fs.existsSync(dir)) fs.rmSync(dir, {recursive:true}); }); if(fs.existsSync('tsconfig.tsbuildinfo')) fs.rmSync('tsconfig.tsbuildinfo'); console.log('🧹 Cleaned dist/ and resources/')\"",
    "prepublishOnly": "npm run build:full"
  },
  "keywords": [
    "node-red",
    "node-red-dashboard-2",
    "alephscript",
    "rooms",
    "socket.io",
    "dashboard"
  ],
  "node-red": {
    "nodes": {
      "alephscript-rooms-config": "dist/nodes/rooms-config.js",
      "alephscript-rooms-server": "dist/nodes/rooms-server.js",
      "alephscript-rooms-agent-dummy": "dist/nodes/rooms-agent-dummy.js",
      "alephscript-rooms-dashboard": "dist/nodes/rooms-dashboard.js"
    }
  },
  "node-red-dashboard-2": {
    "version": "1.0.0",
    "widgets": {
      "alephscript-rooms-dashboard": {
        "output": "rooms-dashboard.umd.js",
        "component": "AlephScriptRoomsDashboard"
      }
    }
  },
  "dependencies": {
    "@alephscript/mcp-core-sdk": "^1.5.0",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/node-red": "^1.3.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.4.17",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vue": "^3.5.13"
  },
  "peerDependencies": {
    "node-red": ">=3.0.0"
  },
  "author": {
    "name": "AlephScript Ops",
    "email": "ops@escrivivir.co",
    "url": "https://escrivivir.co"
  },
  "maintainers": [
    {
      "name": "AlephScript Ops",
      "email": "ops@escrivivir.co",
      "url": "https://escrivivir.co"
    }
  ],
  "license": "MIT"
}
