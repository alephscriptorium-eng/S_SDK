  {
    "id": "f1-filter-kinds",
    "type": "function",
    "z": "z08-f1-oreja",
    "name": "Filtrar state|track|ledger|SET_STATE + taxonomía",
    "func": "// Patrón 3d-monitor channels.mjs (lectura; no se importa código).\nconst EVENT_CHANNEL = {\n  PING: 'sys', PONG: 'sys',\n  HORSE: 'agent', RABBIT: 'agent', SPIDER: 'agent',\n  'selection:cast': 'game',\n  SET_STATE: 'ui', ROOM_MESSAGE: 'app',\n  state: 'game', track: 'game', ledger: 'game', intent: 'game'\n};\n\nconst topic = String(msg.topic || '');\nconst payload = msg.payload;\nconst innerEvent = (payload && typeof payload === 'object' && payload.event)\n  ? String(payload.event)\n  : topic;\n\nconst WATCH = new Set(['state', 'track', 'ledger', 'SET_STATE', 'ROOM_MESSAGE']);\nconst kind = (payload && payload.kind) || (payload && payload.data && payload.data.kind) || null;\nconst isKind = kind && ['state', 'track', 'ledger', 'intent'].includes(String(kind));\nconst isWatch = WATCH.has(topic) || WATCH.has(innerEvent) || isKind;\n\nif (!isWatch && topic !== 'auth_error') {\n  return null;\n}\n\nconst channel = EVENT_CHANNEL[innerEvent] || EVENT_CHANNEL[topic] || (isKind ? 'game' : 'app');\nconst counts = context.get('taxonomy') || { sys: 0, app: 0, ui: 0, agent: 0, game: 0 };\ncounts[channel] = (counts[channel] || 0) + 1;\ncontext.set('taxonomy', counts);\n\nconst line = {\n  at: new Date().toISOString(),\n  topic,\n  innerEvent,\n  kind,\n  channel,\n  room: (payload && (payload.room || payload.data && payload.data.room)) || null,\n  from: msg.alephscript && msg.alephscript.clientName\n};\n\nconst recent = context.get('recent') || [];\nrecent.unshift(line);\nif (recent.length > 40) recent.length = 40;\ncontext.set('recent', recent);\n\nmsg.payload = { line, recent, taxonomy: counts };\nmsg.topic = 'oreja:' + channel;\nreturn msg;",
    "outputs": 1,
    "timeout": "",
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 720,
    "y": 140,
    "wires": [
      [
        "f1-debug",
        "f1-ui-oreja",
        "f1-ui-taxonomia"
      ]
    ]
  },
