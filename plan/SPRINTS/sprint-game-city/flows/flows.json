  {
    "id": "f3-aggregate",
    "type": "function",
    "z": "z08-f3-ciudad",
    "name": "Agregar fleet + volumen + distritos",
    "func": "const raw = msg.payload || {};\nconst snapshot = raw.snapshot || { ok: false };\nconst serversBody = raw.servers || {};\nconst firehose = raw.firehose || {};\nconst cacheStats = raw.cacheStats || {};\nconst cacheLineas = raw.cacheLineas || {};\n\nlet servers = [];\nif (Array.isArray(serversBody)) servers = serversBody;\nelse if (Array.isArray(serversBody.servers)) servers = serversBody.servers;\nelse if (serversBody && typeof serversBody === 'object' && serversBody.ok === false) servers = [];\nelse if (serversBody && typeof serversBody === 'object') {\n  servers = Object.keys(serversBody).filter(k => k !== 'ok' && k !== 'statusCode' && k !== 'error')\n    .map(id => ({ id, ...(typeof serversBody[id] === 'object' ? serversBody[id] : {}) }));\n}\n\nconst firehoseDown = !!(firehose && firehose.ok === false);\nconst cacheDown = !!(cacheStats && cacheStats.ok === false);\nconst bothDown = firehoseDown && cacheDown;\nlet volume = {\n  source: bothDown ? 'fixture' : 'live',\n  firehose,\n  cacheStats,\n  cacheLineas,\n  note: null,\n  stats: (cacheStats && cacheStats.stats) || cacheStats || firehose || { files: 0, volumes: [] }\n};\n\nif (bothDown) {\n  // Mirror fixtures/empty-volume-stats.json (Z01 blanda).\n  volume = {\n    ok: true,\n    source: 'fixture',\n    note: 'Z01 pendiente o browsers caídos — demo con volumen vacío (ver flows/fixtures/empty-volume-stats.json)',\n    volumes: [],\n    stats: { files: 0, bytes: 0, corpora: 0 },\n    lineas: [],\n    firehose,\n    cacheStats,\n    cacheLineas\n  };\n}\n\nconst DISTRICTS = {\n  'Zigurat': [/vscode/i, /zigurat/i, /extension/i],\n  'Runtime/MCP': [/mcp/i, /aaia/i, /copilot/i, /state.?machine/i, /novelist/i, /console/i, /editor/i],\n  'Editores': [/blockly/i, /wiring/i, /prolog/i, /typed/i, /workflow/i, /n8n/i, /hypergraph/i],\n  'Lore/voz': [/lore/i, /document/i, /onfalo/i, /vector/i, /asesor/i],\n  'Red/stream': [/stream/i, /bot.?hub/i, /blockchain/i, /network/i, /firehose/i],\n  'Infra/UI': [/vibe/i, /three/i, /ui.?sdk/i, /cache/i, /scriptorium/i, /vps/i]\n};\n\nconst byDistrict = {\n  'Zigurat': [], 'Runtime/MCP': [], 'Editores': [], 'Lore/voz': [], 'Red/stream': [], 'Infra/UI': [], 'Otros': []\n};\n\nfor (const s of servers) {\n  const label = String(s.id || s.name || s.label || JSON.stringify(s)).slice(0, 120);\n  let placed = false;\n  for (const [dist, patterns] of Object.entries(DISTRICTS)) {\n    if (patterns.some(re => re.test(label))) {\n      byDistrict[dist].push(label);\n      placed = true;\n      break;\n    }\n  }\n  if (!placed) byDistrict['Otros'].push(label);\n}\n\nconst health = snapshot.health || snapshot.monitor || {};\nconst summary = {\n  at: new Date().toISOString(),\n  snapshotOk: !(snapshot && snapshot.ok === false),\n  serversCount: servers.length,\n  volumeSource: volume.source,\n  volumeNote: volume.note || null,\n  volumeStats: volume.stats || cacheStats || firehose || null,\n  byDistrict,\n  snapshotHealth: health\n};\n\nmsg.payload = summary;\nmsg.ciudad = { snapshot, servers, volume, byDistrict, summary };\nreturn msg;",
