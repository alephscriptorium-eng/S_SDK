    "head": "",
    "format": "<template>\n  <div style=\"display:grid;grid-template-columns:repeat(5,1fr);gap:8px;font:13px/1.3 system-ui,sans-serif\">\n    <div v-for=\"k in ['sys','app','ui','agent','game']\" :key=\"k\" style=\"padding:8px;border:1px solid #334155;border-radius:6px;text-align:center\">\n      <div style=\"opacity:.7;text-transform:uppercase;font-size:11px\">{{ k }}</div>\n      <div style=\"font-size:22px;font-weight:600\">{{ (msg?.payload?.taxonomy||{})[k] || 0 }}</div>\n    </div>\n  </div>\n</template>",
